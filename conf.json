{
    "tags": {
        "allowUnknownTags": true
    },
    "source": {
        "include": ["src/material"],
        "exclude": [],
        "includePattern": ".+\\.js(doc|x)?$",
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "plugins": ["plugins/markdown"],
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false,
        "default": {
            "outputSourceFiles": true
        }
    },
    "opts": {
        "template": "templates/markdown",
        "encoding": "utf8",
        "destination": "./out/",
        "recurse": true
    }
}
